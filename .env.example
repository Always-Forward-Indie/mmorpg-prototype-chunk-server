# Chunk Server Configuration
# Copy this file to .env and fill in real values

# Game Server (upstream connection)
GAME_SERVER_HOST=127.0.0.1
GAME_SERVER_PORT=27016
GAME_SERVER_MAX_CLIENTS=3000

# Chunk Server
SERVER_HOST=0.0.0.0
SERVER_PORT=27017
SERVER_MAX_CLIENTS=3000

# Logging
LOG_LEVEL=info
LOG_LEVEL_NETWORK=warn
LOG_LEVEL_GAMELOOP=warn
LOG_LEVEL_EVENTS=warn
